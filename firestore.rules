rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read any authenticated, write own doc only (or allow others to update karma)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['karma'])
      );
      allow create, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Items: read any authenticated, write own items
    match /items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.reportedBy == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.reportedBy == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if request.auth != null && resource.data.reportedBy == request.auth.uid;
    }

    // Claims: participants only
    match /claims/{claimId} {
      allow read: if request.auth != null
        && (resource.data.claimantId == request.auth.uid
            || get(/databases/$(database)/documents/items/$(resource.data.itemId)).data.reportedBy == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.claimantId == request.auth.uid;
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/items/$(resource.data.itemId)).data.reportedBy == request.auth.uid;
    }

    // Chats: only participants can read or write the chat document
    match /chats/{chatId} {
      // Create: only the participants themselves can create a chat
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Read: only if you are a participant
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Update/delete: only participants
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Messages subcollection: both participants can read and create
      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}